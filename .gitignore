# ═══════════════════════════════════════════
# Suvichaar Admin — .gitignore
# ═══════════════════════════════════════════

# ── Dependencies ──
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ──
/.next/
/out/
/build/
next-env.d.ts

# ── Testing ──
/coverage/

# ── Environment Variables ──
.env
.env.*
!.env.example

# ── OS Files ──
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ── Editor / IDE ──
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.gemini/

# ── Debug Logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── TypeScript ──
*.tsbuildinfo

# ── Build Artifacts ──
*.pem

# ── Vercel ──
.vercel

# ── Package Manager Locks (keep only npm) ──
yarn.lock
pnpm-lock.yaml
bun.lockb
